{
  "name": "ai-support-app",
  "private": true,
  "scripts": {
    "build": "pnpm build:client && pnpm build:backend",
    "build:client": "pnpm --filter ./apps/client build",
    "build:backend": "python -m compileall -q apps/server/app",
    "dev:client": "pnpm --filter ./apps/client dev",
    "dev:backend": "cd apps/server && python -m uvicorn app.main:app --reload",
    "dev": "concurrently \"pnpm dev:client\" \"pnpm dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}